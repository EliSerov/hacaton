# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=articles

# --- Models (open-source, локально) ---
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
GEN_MODEL=Qwen/Qwen2.5-1.5B-Instruct
DEVICE=auto

# --- Ingestion ---
AUTO_INGEST=1
CSV_GLOB=/app/data/*.csv
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# --- Retrieval ---
TOP_K=5

# --- API Security (опционально) ---
API_KEY=

# --- Telegram (Aiogram) ---
BOT_TOKEN=6710679925:AAF1KSXQ6pePNO8AwwNa0axh1CqzRArtskc
RAG_API_URL=http://api:8000
ALLOWED_USER_IDS=
